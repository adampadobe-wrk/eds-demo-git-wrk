# Adobe Integration (for Launch API / AEP automation)
# Copy to .env and fill in values. NEVER commit .env to git.
#
# Get these from: https://developer.adobe.com/console
# Use OAuth Server-to-Server credential (JWT is deprecated)
# Add "Adobe Experience Platform Data Collection" or "Experience Platform Launch API" to your project

ADOBE_CLIENT_ID=your_client_id
ADOBE_CLIENT_SECRET=your_client_secret
ADOBE_ORG_ID=your_org_id@AdobeOrg
# Optional: OAuth scope (default works for Data Collection API)
# ADOBE_OAUTH_SCOPE=https://ims-na1.adobelogin.com/s/ent_dataservices_sdk
