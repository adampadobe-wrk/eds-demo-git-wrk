# Adobe Integration (for Launch API / AEP automation)
# Copy to .env and fill in values. NEVER commit .env to git.
#
# Get these from: https://developer.adobe.com/console
# Use OAuth Server-to-Server credential (JWT is deprecated)
# Add "Adobe Experience Platform Data Collection" or "Experience Platform Launch API" to your project

ADOBE_CLIENT_ID=your_client_id
ADOBE_CLIENT_SECRET=your_client_secret
ADOBE_ORG_ID=your_org_id@AdobeOrg
# OAuth scope – REQUIRED for Launch/Reactor API. Without it: "invalid_target_scope".
# Use the full scope from Developer Console → OAuth S2S credential → Generate access token.
# If you set a minimal scope (e.g. openid,session,AdobeID only), token lacks Launch access → "no-available-orgs".
# Either omit this to use the script default, or set the full scope (20+ comma-separated values).
# ADOBE_OAUTH_SCOPE=cjm.suppression_service.client.delete,cjm.suppression_service.client.all,openid,...

# Launch (Tags) - for fetch-launch-data-elements.js, launch-api-link-click-rule.js
# Company ID: CO72fab825b7fc466d94f9ef13723dde55
# Property ID: PR5057e9b14a5e4fae942acbb8a85da6c8
LAUNCH_PROPERTY_ID=PR5057e9b14a5e4fae942acbb8a85da6c8
