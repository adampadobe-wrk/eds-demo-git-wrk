# Adobe Integration (for Launch API / AEP automation)
# Copy to .env and fill in values. NEVER commit .env to git.
#
# Get these from: https://developer.adobe.com/console
# Required scope for Launch API: Adobe Experience Platform Data Collection

ADOBE_CLIENT_ID=your_client_id
ADOBE_CLIENT_SECRET=your_client_secret
ADOBE_TECHNICAL_ACCOUNT_ID=your_tech_account@techacct.adobe.com
ADOBE_ORG_ID=your_org_id@AdobeOrg
# Path to private key .pem file (for JWT auth)
ADOBE_PRIVATE_KEY_PATH=./private.key
